{
  "rules": {
    ".read": false,
    ".write": false,
    "cafes": {
      "$cafeId": {
        "menu": {
          ".read": true,
          ".write": true
        },
        "orders": {
          ".read": true,
          "$orderId": {
            ".write": true,
            ".validate": "newData.hasChildren(['id', 'cafeId', 'status', 'createdAt', 'pickupTime', 'items'])"
          }
        }
      }
    }
  }
}
